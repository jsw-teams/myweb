---
import { site } from '../data/site';

const languages = [
  { code: 'zh-CN', label: '简体中文', href: '/zh-CN/' },
  { code: 'zh-TW', label: '繁體中文', href: '/zh-TW/' },
  { code: 'en', label: 'English', href: '/en/' }
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index, follow" />
    <title>JS.Gripe / 技诉</title>
    <meta name="description" content="JS.Gripe / 技诉的语言选择页。" />
    <link rel="canonical" href="https://js.gripe/" />
    <link rel="icon" href={site.icon} />
    <link rel="apple-touch-icon" href={site.icon} />
    {languages.map((language) => (
      <link rel="alternate" hreflang={language.code} href={`https://js.gripe${language.href}`} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://js.gripe/" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content="JS.Gripe / 技诉" />
    <meta property="og:description" content="JS.Gripe / 技诉的语言选择页。" />
    <meta property="og:url" content="https://js.gripe/" />
    <meta property="og:image" content={`https://js.gripe${site.icon}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="JS.Gripe / 技诉" />
    <meta name="twitter:description" content="JS.Gripe / 技诉的语言选择页。" />
    <meta name="twitter:image" content={`https://js.gripe${site.icon}`} />
    <script is:inline>
      const supported = ['zh-CN', 'zh-TW', 'en'];
      const pick = (tags) => {
        for (const tag of tags || []) {
          const normalized = String(tag).toLowerCase();
          if (normalized === 'zh-tw' || normalized === 'zh-hk' || normalized === 'zh-mo') return 'zh-TW';
          if (normalized === 'zh-cn' || normalized.startsWith('zh')) return 'zh-CN';
          if (normalized.startsWith('en')) return 'en';
        }
        return 'zh-CN';
      };
      location.replace(`/${supported.includes(pick(navigator.languages)) ? pick(navigator.languages) : 'zh-CN'}/`);
    </script>
  </head>
  <body>
    <main>
      <h1>JS.Gripe / 技诉</h1>
      <noscript>
        <p>请选择语言 / 請選擇語言 / Choose a language:</p>
        <ul>
          {languages.map((language) => (
            <li><a href={language.href} hreflang={language.code}>{language.label}</a></li>
          ))}
        </ul>
      </noscript>
    </main>
  </body>
</html>
