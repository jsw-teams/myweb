---
import { languageNames, type Lang, type PageKey } from '../i18n/config';
import { messages } from '../i18n/messages';
import { getLanguageAlternates } from '../lib/i18n';

type Props = {
  lang: Lang;
  page: PageKey;
};

const { lang, page } = Astro.props;
const alternates = getLanguageAlternates(page);
const t = messages[lang];
---
<nav class="language-links" aria-label={t.availableLanguages}>
  <span>{t.availableLanguages}</span>
  <ul>
    {alternates.map((alternate) => (
      <li>
        <a
          href={alternate.href}
          hreflang={alternate.lang}
          aria-current={alternate.lang === lang ? 'page' : undefined}
        >
          {languageNames[alternate.lang]}
        </a>
      </li>
    ))}
  </ul>
</nav>
