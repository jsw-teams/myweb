---
import { site } from '../data/site';

type Props = {
  alt: string;
  image?: string;
  compact?: boolean;
};

const { alt, image = site.mascot, compact = false } = Astro.props;
---
<aside class:list={['mascot-card', { compact }]}>
  <img class="mascot-sheet" src={image} alt={alt} loading={compact ? 'lazy' : 'eager'} />
</aside>
