---
import { site } from '../data/site';
import { withBase } from '../lib/i18n';

type Props = {
  alt: string;
  image?: string;
  compact?: boolean;
};

const { alt, image = site.mascot, compact = false } = Astro.props;
const baseName = image.includes('mascot-contact')
  ? 'mascot-contact'
  : image.includes('mascot-friends')
    ? 'mascot-friends'
    : 'mascot-sheet';
const imageSizes = baseName === 'mascot-sheet' ? [480, 640, 800] : [320, 480];
const mobileImageSize = baseName === 'mascot-sheet' ? 320 : 320;
const renderedWidth = compact ? 320 : 390;
const renderedHeight = compact ? 320 : 390;
---
<aside class:list={['mascot-card', { compact }]}>
  <picture>
    <source
      media="(max-width: 900px)"
      type="image/avif"
      srcset={withBase(`/assets/brand/generated/${baseName}-${mobileImageSize}.avif`)}
    />
    <source
      media="(max-width: 900px)"
      type="image/webp"
      srcset={withBase(`/assets/brand/generated/${baseName}-${mobileImageSize}.webp`)}
    />
    <source
      type="image/avif"
      srcset={imageSizes.map((size) => `${withBase(`/assets/brand/generated/${baseName}-${size}.avif`)} ${size}w`).join(', ')}
      sizes={compact ? '320px' : '390px'}
    />
    <source
      type="image/webp"
      srcset={imageSizes.map((size) => `${withBase(`/assets/brand/generated/${baseName}-${size}.webp`)} ${size}w`).join(', ')}
      sizes={compact ? '320px' : '390px'}
    />
    <img
      class="mascot-sheet"
      src={withBase(image)}
      alt={alt}
      width={renderedWidth}
      height={renderedHeight}
      loading={compact ? 'lazy' : 'eager'}
      decoding="async"
      fetchpriority={compact ? undefined : 'high'}
    />
  </picture>
</aside>
