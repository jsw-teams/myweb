---
import { site } from '../data/site';
import { navItems } from '../data/nav';
import { messages } from '../i18n/messages';
import type { Lang, PageKey } from '../i18n/config';
import { getPagePath, withBase } from '../lib/i18n';

type Props = {
  lang: Lang;
  page: PageKey;
};

const { lang, page } = Astro.props;
const t = messages[lang];
---
<header class="site-header">
  <a class="brand" href={getPagePath(lang, 'home')} aria-label={site.name}>
    <picture>
      <source
        type="image/avif"
        srcset={`${withBase('/assets/brand/generated/site-icon-48.avif')} 1x, ${withBase('/assets/brand/generated/site-icon-96.avif')} 2x`}
      />
      <source
        type="image/webp"
        srcset={`${withBase('/assets/brand/generated/site-icon-48.webp')} 1x, ${withBase('/assets/brand/generated/site-icon-96.webp')} 2x`}
      />
      <img
        src={withBase('/assets/brand/generated/site-icon-48.png')}
        alt=""
        width="44"
        height="44"
        decoding="async"
      />
    </picture>
    <span>{site.shortName}</span>
  </a>
  <nav class="site-nav" aria-label={t.navLabel}>
    {navItems.map((item) => (
      <a href={getPagePath(lang, item)} aria-current={page === item ? 'page' : undefined}>
        {t.cards[item as keyof typeof t.cards] ?? t.pages[item].heading}
      </a>
    ))}
  </nav>
</header>
