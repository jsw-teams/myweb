---
import LanguageLinks from '../../components/LanguageLinks.astro';
import MascotCard from '../../components/MascotCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { languages, type PageKey } from '../../i18n/config';
import { messages } from '../../i18n/messages';
import { getLang } from '../../lib/i18n';
import { getPublicProjects } from '../../lib/projects';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLang(Astro.params.lang);
const page: PageKey = 'projects';
const t = messages[lang];
const projects = getPublicProjects();
---
<BaseLayout lang={lang} page={page}>
  <LanguageLinks lang={lang} page={page} />
  <section class="page-heading" aria-labelledby="page-title">
    <h1 id="page-title">{t.pages.projects.heading}</h1>
    <p class="lead">{t.pages.projects.intro}</p>
  </section>
  <div class="content-grid">
    <section class="list-grid" aria-label={t.pages.projects.heading}>
      {projects.length === 0 ? (
        <div class="empty-state">
          <h2>{t.projects.emptyTitle}</h2>
          <p>{t.projects.emptyText}</p>
        </div>
      ) : (
        projects.map((project) => (
          <article class="entry-card">
            <h2>{project.name}</h2>
            <p>{project.description}</p>
            <a class="button-link" href={project.url} rel="noopener noreferrer">{project.url}</a>
          </article>
        ))
      )}
    </section>
    <MascotCard image="/assets/brand/mascot-laptop.png" compact alt={t.projects.mascotAlt} />
  </div>
</BaseLayout>
