---
import LanguageLinks from '../../components/LanguageLinks.astro';
import MascotCard from '../../components/MascotCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { contactLinks } from '../../data/contact';
import { languages, type PageKey } from '../../i18n/config';
import { messages } from '../../i18n/messages';
import { getLang } from '../../lib/i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLang(Astro.params.lang);
const page: PageKey = 'contact';
const t = messages[lang];
---
<BaseLayout lang={lang} page={page}>
  <LanguageLinks lang={lang} page={page} />
  <section class="page-heading" aria-labelledby="page-title">
    <h1 id="page-title">{t.pages.contact.heading}</h1>
    <p class="lead">{t.pages.contact.intro}</p>
  </section>
  <div class="content-grid">
    <section class="list-grid" aria-label={t.pages.contact.heading}>
      <div class="panel notice">
        <p>{t.contact.safetyNote}</p>
      </div>
      {contactLinks.length === 0 ? (
        <div class="empty-state">
          <h2>{t.contact.emptyTitle}</h2>
          <p>{t.contact.emptyText}</p>
        </div>
      ) : (
        contactLinks.map((item) => (
          <article class="entry-card">
            <h2><a href={item.href} rel="noopener noreferrer">{item.label}</a></h2>
            {item.note && <p>{item.note}</p>}
          </article>
        ))
      )}
    </section>
    <MascotCard image="/assets/brand/mascot-contact.png" compact alt={t.contact.mascotAlt} />
  </div>
</BaseLayout>
