---
import LanguageLinks from '../../components/LanguageLinks.astro';
import MascotCard from '../../components/MascotCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { friends } from '../../data/friends';
import { languages, type PageKey } from '../../i18n/config';
import { messages } from '../../i18n/messages';
import { getLang } from '../../lib/i18n';

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const lang = getLang(Astro.params.lang);
const page: PageKey = 'friends';
const t = messages[lang];
---
<BaseLayout lang={lang} page={page}>
  <LanguageLinks lang={lang} page={page} />
  <section class="page-heading" aria-labelledby="page-title">
    <h1 id="page-title">{t.pages.friends.heading}</h1>
    <p class="lead">{t.pages.friends.intro}</p>
  </section>
  <div class="content-grid">
    <section class="list-grid" aria-label={t.pages.friends.heading}>
      {friends.length === 0 ? (
        <div class="empty-state">
          <h2>{t.friends.emptyTitle}</h2>
          <p>{t.friends.emptyText}</p>
        </div>
      ) : (
        friends.map((friend) => (
          <article class="entry-card">
            <h2><a href={friend.url} rel="noopener noreferrer">{friend.name}</a></h2>
            <p>{friend.description}</p>
            {friend.lang && <p>{t.friends.langLabel}: {friend.lang}</p>}
          </article>
        ))
      )}
    </section>
    <MascotCard image="/assets/brand/mascot-friends.png" compact alt={t.friends.mascotAlt} />
  </div>
</BaseLayout>
